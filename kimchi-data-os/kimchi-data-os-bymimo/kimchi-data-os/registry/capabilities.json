{
  "version": "1.0.0",
  "capabilities": [
    {
      "id": "forecasting",
      "name": "Time Series Forecasting",
      "description": "Generate forecasts with uncertainty quantification and scenario analysis",
      "workflow": "workflows/forecasting.md",
      "uses": {
        "agents": ["agent-data-auditor", "agent-data-analyst", "agent-forecast-engineer", "agent-statistician", "agent-report-writer"],
        "knowledge": ["knowledge/forecasting.md", "knowledge/forecasting-ecosystem.md"],
        "templates": ["templates/prediction.md"]
      },
      "requires": {
        "inputs": ["time_column", "target_variable", "historical_data"],
        "optional": ["exogenous_variables", "forecast_horizon", "confidence_level"]
      },
      "outputs": ["forecast_report", "confidence_intervals", "scenarios", "visualizations"],
      "triggers": ["forecast", "predict", "future", "trend", "projection"]
    },
    {
      "id": "classification",
      "name": "Classification Modeling",
      "description": "Build binary or multi-class prediction models",
      "workflow": "workflows/classification.md",
      "uses": {
        "agents": ["agent-data-auditor", "agent-feature-engineer", "agent-data-scientist", "agent-statistician", "agent-report-writer"],
        "knowledge": ["knowledge/machine-learning.md", "knowledge/feature-engineering.md"],
        "templates": ["templates/prediction.md"]
      },
      "requires": {
        "inputs": ["target_variable", "features", "labeled_data"],
        "optional": ["class_weights", "evaluation_metric"]
      },
      "outputs": ["trained_model", "performance_metrics", "feature_importance", "model_card"],
      "triggers": ["classify", "predict", "category", "churn", "fraud", "segment"]
    },
    {
      "id": "regression",
      "name": "Regression Modeling",
      "description": "Build continuous outcome prediction models",
      "workflow": "workflows/regression.md",
      "uses": {
        "agents": ["agent-data-auditor", "agent-feature-engineer", "agent-data-scientist", "agent-statistician", "agent-report-writer"],
        "knowledge": ["knowledge/machine-learning.md", "knowledge/feature-engineering.md"],
        "templates": ["templates/prediction.md"]
      },
      "requires": {
        "inputs": ["target_variable", "features", "data"],
        "optional": ["regularization", "interpretability_required"]
      },
      "outputs": ["trained_model", "performance_metrics", "residual_analysis", "feature_importance"],
      "triggers": ["regression", "predict", "continuous", "estimate", "score"]
    },
    {
      "id": "clustering",
      "name": "Customer Segmentation",
      "description": "Segment customers or entities into meaningful groups",
      "workflow": "workflows/clustering.md",
      "uses": {
        "agents": ["agent-data-auditor", "agent-data-analyst", "agent-data-scientist", "agent-report-writer"],
        "knowledge": ["knowledge/machine-learning.md", "knowledge/business-frameworks.md"],
        "templates": ["templates/eda.md"]
      },
      "requires": {
        "inputs": ["data", "segmentation_features"],
        "optional": ["num_clusters", "segmentation_type"]
      },
      "outputs": ["segment_assignments", "segment_profiles", "cluster_visualization"],
      "triggers": ["segment", "cluster", "group", "segmentation", "cohort"]
    },
    {
      "id": "churn_prediction",
      "name": "Churn Prediction",
      "description": "Predict and prevent customer churn",
      "workflow": "workflows/churn.md",
      "uses": {
        "agents": ["agent-data-auditor", "agent-feature-engineer", "agent-data-scientist", "agent-statistician", "agent-report-writer"],
        "knowledge": ["knowledge/machine-learning.md", "knowledge/business-frameworks.md"],
        "templates": ["templates/prediction.md", "templates/executive-report.md"]
      },
      "requires": {
        "inputs": ["customer_data", "churn_definition", "historical_period"],
        "optional": ["retention_budget", "intervention_threshold"]
      },
      "outputs": ["churn_probabilities", "risk_segments", "intervention_recommendations", "retention_roi"],
      "triggers": ["churn", "retain", "attrition", "流失"]
    },
    {
      "id": "root_cause_analysis",
      "name": "Root Cause Analysis",
      "description": "Identify underlying causes of business problems",
      "workflow": "workflows/root-cause.md",
      "uses": {
        "agents": ["agent-business-consultant", "agent-data-analyst", "agent-statistician", "agent-executive-advisor", "agent-report-writer"],
        "knowledge": ["knowledge/business-frameworks.md"],
        "templates": ["templates/executive-report.md"]
      },
      "requires": {
        "inputs": ["problem_description", "data", "timeline"],
        "optional": ["suspected_causes", "stakeholder_hypotheses"]
      },
      "outputs": ["root_causes", "evidence_chain", "recommendations", "confidence_assessment"],
      "triggers": ["why", "cause", "reason", "diagnosis", "investigate"]
    },
    {
      "id": "ab_testing",
      "name": "A/B Testing",
      "description": "Design and analyze controlled experiments",
      "workflow": "workflows/ab-testing.md",
      "uses": {
        "agents": ["agent-business-consultant", "agent-data-auditor", "agent-statistician", "agent-executive-advisor", "agent-report-writer"],
        "knowledge": ["knowledge/statistics.md"],
        "templates": ["templates/prediction.md", "templates/executive-report.md"]
      },
      "requires": {
        "inputs": ["hypothesis", "primary_metric", "traffic"],
        "optional": ["guardrail_metrics", "minimum_detectable_effect"]
      },
      "outputs": ["experiment_design", "statistical_results", "business_recommendation", "power_analysis"],
      "triggers": ["test", "experiment", "a/b", "variant", "control"]
    },
    {
      "id": "cohort_analysis",
      "name": "Cohort Analysis",
      "description": "Analyze customer behavior over time by cohorts",
      "workflow": "workflows/cohort-analysis.md",
      "uses": {
        "agents": ["agent-data-auditor", "agent-data-analyst", "agent-report-writer"],
        "knowledge": ["knowledge/business-frameworks.md"],
        "templates": ["templates/eda.md", "templates/executive-report.md"]
      },
      "requires": {
        "inputs": ["user_id", "event_date", "event_type"],
        "optional": ["cohort_definition", "retention_window"]
      },
      "outputs": ["retention_curves", "cohort_comparison", "revenue_by_cohort"],
      "triggers": ["cohort", "retention", "lifecycle", "journey"]
    },
    {
      "id": "eda",
      "name": "Exploratory Data Analysis",
      "description": "Systematic exploration of data to understand patterns",
      "workflow": "workflows/eda.md",
      "uses": {
        "agents": ["agent-data-auditor", "agent-data-analyst", "agent-report-writer"],
        "knowledge": ["knowledge/statistics.md", "knowledge/visualization.md"],
        "templates": ["templates/eda.md"]
      },
      "requires": {
        "inputs": ["data"],
        "optional": ["focus_variables", "business_context"]
      },
      "outputs": ["data_profile", "distributions", "correlations", "key_findings", "visualizations"],
      "triggers": ["explore", "analyze", "understand", "describe", "summary"]
    },
    {
      "id": "dashboard_design",
      "name": "Dashboard Design",
      "description": "Design and specify BI dashboards",
      "workflow": "workflows/dashboard.md",
      "uses": {
        "agents": ["agent-business-consultant", "agent-data-analyst", "agent-dashboard-designer", "agent-report-writer"],
        "knowledge": ["knowledge/visualization.md", "knowledge/visualization-library.md"],
        "templates": ["templates/dashboard.md"]
      },
      "requires": {
        "inputs": ["business_metrics", "stakeholder_needs"],
        "optional": ["data_sources", "update_frequency", "interactivity_level"]
      },
      "outputs": ["dashboard_specification", "kpi_definitions", "visualization_recommendations"],
      "triggers": ["dashboard", "report", "monitor", "track", "kpi"]
    }
  ]
}
